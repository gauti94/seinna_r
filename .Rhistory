knitr::opts_chunk$set(echo = TRUE)
library(tidyverse)
library(dplyr) # fyrir filter
library(scales)
library(knitr)
library(ggplot2)
jst <- read.csv("survey_results_public_rev.csv", header = T, sep =",")
jst <- filter(jst, MainBranch=="I am a developer by profession" & Employment=="Employed, full-time" & RemoteWork %in% c("Remote", "In-person") & Currency %in% c("USD\tUnited States dollar", "EUR European Euro"))
jst <- filter(jst, is.na(CompTotal) | CompTotal <= 2000000)
jst$CompTotalUSD <- ifelse(jst$Currency == "EUR European Euro", jst$CompTotal / 0.85, jst$CompTotal)
country_answer_count <- head(count(jst, Country, sort = TRUE), 10)
country_answer_count
jst <- filter(jst, Country %in% c("France", "Spain", "Ukraine"))
jst$MainBranch <- factor(jst$MainBranch)
jst$Employment <- factor(jst$Employment)
jst$RemoteWork <- factor(jst$RemoteWork)
jst$Country <- factor(jst$Country)
jst$Currency <- factor(jst$Currency)
jst$EdLevel <- factor(jst$EdLevel)
levels(jst$EdLevel) # Sjá núverandi nöfn
levels(jst$EdLevel) <- c("Tveggja ára háskólagráða", "Bakkalárgráða", "Meistaragráða", "Grunnskólanám", "Fagleg háskólagráða", "Framhaldsskólanám", "Háskólanám án gráðu", "Annað")
levels(jst$Country) <- c("Frakkland", "Spánn", "Úkraína")
ggplot(jst, aes(x = CompTotalUSD)) +
geom_histogram(bins = 24) + scale_x_continuous(labels = dollar)
cutoff_99 <- quantile(jst$CompTotalUSD, 0.99, na.rm = TRUE)
filtered_CompTotalUSD <- jst %>%
filter(CompTotalUSD < cutoff_99)
ggplot(filtered_CompTotalUSD, aes(x = CompTotalUSD)) +
geom_histogram(bins = 24) + scale_x_continuous(labels = dollar)
ggplot(filtered_CompTotalUSD, aes(x=Country, y= CompTotalUSD)) + geom_boxplot() +
scale_y_continuous(labels = dollar)
ggplot(filtered_CompTotalUSD, aes(x=EdLevel, y=CompTotalUSD)) +
geom_boxplot() +
scale_y_continuous(labels = dollar) +
theme(axis.text.x = element_text(angle = 90, vjust = 0.5, hjust = 1)) +
facet_wrap(~ Country)
ggplot(jst, aes(x=YearsCodePro, y=TimeAnswering)) +
geom_boxplot()
data_AI <- jst %>%
filter(!is.na(YearsCodePro),
!is.na(AIThreat))
ggplot(data_AI, aes(x = AIThreat, y = YearsCodePro)) +
geom_boxplot()
tafla_n <- jst %>%
group_by(Country, EdLevel) %>%
summarise(Fjoldi = n(), .groups = "drop")
tafla_n
tafla_o <- jst %>%
group_by(Country, EdLevel) %>%
summarise(Fjoldi = n(), .groups = "drop") %>%
group_by(Country) %>%
mutate(Hlutfall = Fjoldi / sum(Fjoldi)) %>%
ungroup() %>%
mutate(Hlutfall = percent(Hlutfall, accuracy = 0.1))
tafla_o
tafla_p <- jst %>%
group_by(Country, EdLevel) %>%
summarise(
Fjoldi = n(),
Medal = mean(CompTotalUSD, na.rm = TRUE),
Midgildi = median(CompTotalUSD, na.rm = TRUE),
Stadalfravik = sd(CompTotalUSD, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(
Medal = dollar(round(Medal, 0)),
Midgildi = dollar(round(Midgildi, 0)),
Stadalfravik = dollar(round(Stadalfravik, 0))
)
kable(tafla_p)
View(data_AI)
knitr::opts_chunk$set(echo = TRUE)
library(tidyverse)
library(dplyr) # fyrir filter
library(scales)
library(knitr)
library(ggplot2)
jt <- read.csv("survey_results_public_rev.csv", header = T, sep =",")
jt <- filter(jt, MainBranch=="I am a developer by profession" & Employment=="Employed, full-time" & RemoteWork %in% c("Remote", "In-person") & Currency %in% c("USD\tUnited States dollar", "EUR European Euro"))
jt <- filter(jt, is.na(CompTotal) | CompTotal <= 2000000)
jt$CompTotalUSD <- ifelse(jt$Currency == "EUR European Euro", jt$CompTotal / 0.85, jt$CompTotal)
View(country_answer_count)
set.seed(40)
jt %>%
group_by(Country) %>%
sample_n(size = 200) -> urtak
